# Adapter: "discord", "web", or "both"
ADAPTER=web

# Required for Discord adapter
DISCORD_TOKEN=your_discord_bot_token
DISCORD_APP_ID=your_discord_app_id

# Google Cloud Text-to-Speech API key (used by web adapter TTS)
GOOGLE_API_KEY=your_google_api_key

# Optional

# Comma/space-separated Discord user IDs allowed to interact with the bot (empty = allow all)
# DISCORD_ALLOWED_USER_IDS=123456789012345678,987654321098765432

DEFAULT_WORKDIR=/path/to/default/workdir
PROCESS_MANAGER_PORT=8901
PROCESS_MANAGER_URL=http://localhost:8901/sse
CLAUDE_MAX_TURNS=30
CLAUDE_MAX_BUDGET=5.0
GEMINI_BIN=gemini
WEB_HOST=0.0.0.0
WEB_PORT=3000
DEFAULT_PLUGIN=claude

# Path to session persistence file (empty to disable)
# SESSIONS_FILE=~/.jake-bot/sessions.json
